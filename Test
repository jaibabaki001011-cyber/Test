<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Attendance Buttons</title>
</head>
<body>

  <h2>Attendance Buttons</h2>

  <button onclick="sendData(0)">Button 0</button>
  <button onclick="sendData(1)">Button 1</button>

  <script>
    // आपका Google Apps Script URL यहाँ सेट है
    const GOOGLE_SHEET_URL = "https://script.google.com/macros/s/AKfycbzVwDXCkP6m-Owzko7gWp2hbgaEnn-1CHVDqd9kid0Fmi0y2KLt4T5cjFzQqf6nAAz9/exec";

    function sendData(value) {
      fetch(GOOGLE_SHEET_URL, {
        method: "POST",
        mode: "no-cors",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ attendance: value })
      })
      .then(() => alert("Value " + value + " saved successfully!"))
      .catch(err => {
          console.error("Error:", err);
          alert("Error saving data!");
      });
    }
  </script>

</body>
</html>

